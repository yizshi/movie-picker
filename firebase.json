{
  "hosting": {
    "site": "distributed-denial-of-screen",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/movies",
        "function": "api"
      },
      {
        "source": "/api/meetings",
        "function": "api"
      },
      {
        "source": "/api/results",
        "function": "api"
      },
      {
        "source": "/api/test",
        "function": "api"
      },
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
