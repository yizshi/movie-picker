# Copy this file to .env and fill the values (do NOT commit your real .env to git)

# Admin password hash for /api/admin/login (required)
# Generate with: node generate-password-hash.js
ADMIN_PASSWORD_HASH=$2b$12$replace_me_with_a_real_bcrypt_hash

# TMDB v4 API token (Bearer). Example: "eyJhbGciOiJI..."
TMDB_API_KEY=your_tmdb_bearer_token_here

# Optional: override the port
# PORT=3000
